{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://briefed.sh/schemas/summarize_relevant.v1.json",
  "title": "EmailSummary",
  "description": "Structured output produced by the per-email summarize prompt (plan §14 Phase 3). Generated JSON must match this schema exactly; extra properties are rejected by the Pydantic mirror in app.llm.schemas.EmailSummary.",
  "type": "object",
  "additionalProperties": false,
  "required": ["tldr", "confidence"],
  "properties": {
    "tldr": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "description": "One-sentence faithful summary of the email body."
    },
    "key_points": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 240
      },
      "default": []
    },
    "action_items": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 240
      },
      "default": []
    },
    "entities": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80
      },
      "default": []
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    }
  }
}
