/*
 * Copy to backend.tf and fill in real bucket / table names created by
 * the one-time CloudFormation bootstrap. backend.tf is gitignored.
 */

terraform {
  backend "s3" {
    bucket         = "briefed-tf-state-dev-<account-id>"
    key            = "dev/terraform.tfstate"
    region         = "us-east-1"
    dynamodb_table = "briefed-tf-lock-dev"
    encrypt        = true
  }
}
