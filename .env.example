# Briefed local selector file.
#
# Application secrets do not live in `.env`. Store them in Infisical and run
# developer commands through the Makefile, which wraps secret-bearing processes
# with `infisical run`.
#
# Current Infisical layout:
# - development secrets: project cbd87e9b-3963-4906-b8cc-d479ff5192ed,
#   env dev, path /development
# - production secrets: project cbd87e9b-3963-4906-b8cc-d479ff5192ed,
#   env prod, path /production
#
# Copy this file to `.env` only if you need to override the defaults below.
# Do not put API keys, OAuth secrets, DB URLs, session keys, or AWS secrets here.

BRIEFED_INFISICAL_PROJECT_ID=cbd87e9b-3963-4906-b8cc-d479ff5192ed
BRIEFED_INFISICAL_ENVIRONMENT=dev
BRIEFED_INFISICAL_SECRET_PATH=/development
BRIEFED_INFISICAL_DOMAIN=https://app.infisical.com/api
