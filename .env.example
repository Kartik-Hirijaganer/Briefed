# Briefed — local development environment.
#
# Copy to `.env` (gitignored) and fill in the values you need. In production,
# all of these come from SSM Parameter Store (see plan §19.15); `.env` is
# local-only.

# ---- Core runtime ----
BRIEFED_ENV=local
BRIEFED_RUNTIME=local
LOG_LEVEL=info

# ---- Database ----
# Local docker-compose Postgres:
BRIEFED_DATABASE_URL=postgresql+asyncpg://briefed:briefed@localhost:5432/briefed
# Supabase prod example (via pooler):
# BRIEFED_DATABASE_URL=postgresql+asyncpg://postgres:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ---- LLM providers ----
# OpenRouter routes both Gemini Flash and Claude Haiku 4.5 behind one
# API per ADR 0009.
BRIEFED_OPENROUTER_API_KEY=
# Optional: hard cap on aggregate LLM USD spend per UTC day. Tripping it
# raises LLMBudgetExceededError until the next UTC midnight.
# BRIEFED_DAILY_LLM_USD_CAP=1.00

# ---- Google OAuth (for Gmail ingestion) ----
# The callback path is fixed: /api/v1/oauth/gmail/callback — register the
# full absolute URL in the Google Cloud console.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- Supabase admin surface (optional — used for file storage only) ----
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ---- Session / auth ----
# Random 32-byte hex; re-roll per environment.
SESSION_SIGNING_KEY=

# ---- AWS — LocalStack for dev ----
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# CMK aliases resolved by name; LocalStack creates them via bootstrap script.
BRIEFED_TOKEN_WRAP_KEY_ALIAS=alias/briefed-dev-token-wrap
BRIEFED_CONTENT_KEY_ALIAS=alias/briefed-dev-content-encrypt

# ---- Worker queue URLs (set in Terraform / CI; only needed locally when
# running the SQS dispatcher directly) ----
BRIEFED_INGEST_QUEUE_URL=
# Phase 2 classify queue — the ingest handler enqueues one message per
# un-classified email when this is set.
BRIEFED_CLASSIFY_QUEUE_URL=
# Phase 3 summarize queue — classify handler enqueues when set.
BRIEFED_SUMMARIZE_QUEUE_URL=
# Phase 4 jobs queue — classify handler enqueues ``job_candidate`` rows.
BRIEFED_JOBS_QUEUE_URL=
# Phase 5 unsubscribe / hygiene queue — classify handler enqueues one
# aggregate-run message per account when set. Safe to leave empty in
# local dev (the aggregate only runs when a message arrives on this
# queue).
BRIEFED_UNSUBSCRIBE_QUEUE_URL=
BRIEFED_STORE_RAW_MIME=0
