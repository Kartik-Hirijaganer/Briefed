{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(git push:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)"
    ],
    "ask": [
      "Bash(git push)",
      "Bash(git commit --no-verify:*)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout main)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/typecheck.sh", "timeout": 60 },
          { "type": "command", "command": ".claude/hooks/test.sh", "timeout": 120 },
          { "type": "command", "command": ".claude/hooks/build.sh", "timeout": 90 }
        ]
      }
    ]
  }
}
